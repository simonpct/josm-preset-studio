# Copy to .env.local and fill in
# Register an OAuth2 app at https://www.openstreetmap.org/oauth2/applications
# - Confidential application? NO (public client, PKCE)
# - Permissions: read_prefs, write_prefs
# - Redirect URI (dev): http://127.0.0.1:5173/callback
VITE_OSM_CLIENT_ID=
VITE_OSM_API_BASE=https://api.openstreetmap.org
VITE_OSM_OAUTH_BASE=https://www.openstreetmap.org
